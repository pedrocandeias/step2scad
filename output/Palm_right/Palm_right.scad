palm_shell_sk14a_skin_ats = [24.505204, 24.602602, 24.85, 25.052602, 25.202602, 25.45, 25.652602, 25.705204];  // station positions along y
module palm_shell_sk14a_skin() {
    rings = palm_shell_sk14a_skin_rings;
    ns = len(rings); N = len(rings[0]);
    pts = [for (k = [0:ns-1]) for (r = rings[k]) let(s = palm_shell_sk14a_skin_ats[k]) [r[1], s, r[0]]];
    side = [for (k = [0:ns-2]) for (i = [0:N-1]) each [
        [k*N + i, (k+1)*N + (i+1)%N, k*N + (i+1)%N],
        [k*N + i, (k+1)*N + i, (k+1)*N + (i+1)%N]]];
    cap0 = [[for (i = [0:N-1]) i]];
    cap1 = [[for (i = [N-1:-1:0]) (ns-1)*N + i]];
    polyhedron(points = pts, faces = concat(side, cap0, cap1), convexity = 10);
}

