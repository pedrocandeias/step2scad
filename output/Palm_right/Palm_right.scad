        [k*N + i, (k+1)*N + (i+1)%N, k*N + (i+1)%N],
        [k*N + i, (k+1)*N + i, (k+1)*N + (i+1)%N]]];
    cap0 = [[for (i = [0:N-1]) i]];
    cap1 = [[for (i = [N-1:-1:0]) (ns-1)*N + i]];
    polyhedron(points = pts, faces = concat(side, cap0, cap1), convexity = 10);
}

