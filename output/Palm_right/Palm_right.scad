    rings = palm_shell_sk21b_skin_rings;
    ns = len(rings); N = len(rings[0]);
    pts = [for (k = [0:ns-1]) for (r = rings[k]) let(s = palm_shell_sk21b_skin_ats[k]) [r[1], s, r[0]]];
