// hinge system: clevis gap + knuckle relief + pin bore + snap-pin pockets (all exact B-rep faces; see sources)
module b2_hinge_cuts() {
    union() {
        // b2_gap: clevis gap between exact inner-wall planes #14/#9; front wall = exact tilted plane #63
        rotate([90, 0, 90]) translate([0, 0, 24.573685]) linear_extrude(6) polygon(b2_gap_profile);
        // b2_relief: knuckle relief: exact cylinder face #41
        translate([24.573685, -15.355213, 7.636043]) rotate(a=90, v=[0, 1, 0]) cylinder(h=6, r=7.5, $fn=b2_fn);
        // b2_pin_bore: hinge pin bore: exact cylinder faces #42/#45/#67/#69 between the exact annulus planes
        translate([23.573685, -15.355213, 7.636043]) rotate(a=90, v=[0, 1, 0]) cylinder(h=8, r=2.25, $fn=b2_fn);
        // b2_pocketL: snap-pin pocket: exact full-circle cylinder face #66
        translate([22.294667, -15.355213, 7.636043]) rotate(a=90, v=[0, 1, 0]) cylinder(h=1.279018, r=2.75, $fn=b2_fn);
        // b2_pocketR: right pocket: same radius as face-measured left pocket; breaks out through the skin (annulus plane at the bore band end)
        translate([31.573685, -15.355213, 7.636043]) rotate(a=90, v=[0, 1, 0]) cylinder(h=3.177836, r=2.75, $fn=b2_fn);
    }
}

