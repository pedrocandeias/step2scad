            translate([-9.391926, -0.269785, 0.618182]) cylinder(h=4.442142, r=2, $fn=b1_fn);
        }
        difference() {
            union() {
                // b1_bar0: cord bar: exact boss cylinder face #20 (r=1.445692 at y=-0.601459, z=12.912439); ends extended to the inner walls (the B-rep blends the bar into the walls via small bspline webs)
                translate([-13.391926, -0.601459, 12.912439]) rotate(a=90, v=[0, 1, 0]) cylinder(h=6, r=1.445692, $fn=b1_fn);
                // b1_bar1: cord bar: exact boss cylinder face #19 (r=0.65 at y=-0.075198, z=12.315636); ends extended to the inner walls (the B-rep blends the bar into the walls via small bspline webs)
                translate([-13.391926, -0.075198, 12.315636]) rotate(a=90, v=[0, 1, 0]) cylinder(h=6, r=0.65, $fn=b1_fn);
                // b1_bar2: cord bar: exact boss cylinder face #32 (r=0.65 at y=-1.221051, z=12.413209); ends extended to the inner walls (the B-rep blends the bar into the walls via small bspline webs)
                translate([-13.391926, -1.221051, 12.413209]) rotate(a=90, v=[0, 1, 0]) cylinder(h=6, r=0.65, $fn=b1_fn);
