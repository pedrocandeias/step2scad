// hinge system: clevis gap + knuckle relief + pin bore + snap-pin pockets (all exact B-rep faces; see sources)
module b1_hinge_cuts() {
    union() {
        // b1_gap: clevis gap between exact inner-wall planes #52/#8; front wall = exact tilted plane #57
        rotate([90, 0, 90]) translate([0, 0, -13.391926]) linear_extrude(6) polygon(b1_gap_profile);
        // b1_relief: knuckle relief: exact cylinder face #53
        translate([-13.391926, -15.871401, 7.912065]) rotate(a=90, v=[0, 1, 0]) cylinder(h=6, r=7.5, $fn=b1_fn);
        // b1_pin_bore: hinge pin bore: exact cylinder faces #36/#37/#47/#49 between the exact annulus planes
        translate([-14.391926, -15.871401, 7.912065]) rotate(a=90, v=[0, 1, 0]) cylinder(h=8, r=2.25, $fn=b1_fn);
        // b1_pocketL: snap-pin pocket: exact full-circle cylinder face #14
        translate([-15.673696, -15.871401, 7.912065]) rotate(a=90, v=[0, 1, 0]) cylinder(h=1.28177, r=2.75, $fn=b1_fn);
        // b1_pocketR: right pocket: same radius as face-measured left pocket; breaks out through the skin (annulus plane at the bore band end)
        translate([-6.391926, -15.871401, 7.912065]) rotate(a=90, v=[0, 1, 0]) cylinder(h=3.21414, r=2.75, $fn=b1_fn);
    }
}

// tendon path: bottom slot, top cord scoop and the top channel flat (exact faces / measured laws; see sources)
module b1_tendon_cuts() {
    union() {
        // b1_slot: tendon slot: exact wall planes #52/#8, ceiling plane z=4.560324, r2 ceiling coves (faces #72/#79), front wall plane #6; rear overshoots into the gap
        rotate([0, -90, -90]) translate([0, 0, -13.119785]) linear_extrude(14.85) polygon(b1_slot_profile);
        // b1_scoop: top cord scoop: exact cylinder face #33
        translate([-13.391926, -0.227235, 12.945758]) rotate(a=90, v=[0, 1, 0]) cylinder(h=6, r=3.47866, $fn=b1_fn);
        // b1_channel: top channel floor: exact tilted plane #25 (n=[0.0, 0.061028, 0.998136], d=9.429101) between the inner walls, from the gap to scoop tangency
        rotate([90, 0, 90]) translate([0, 0, -13.391926]) linear_extrude(6) polygon(b1_channel_profile);
    }
}

// material re-added inside the tendon path: post, slot front-corner nooks, cord bar with measured top cut
module b1_tendon_details() {
    union() {
        // b1_post: tendon post: exact wall planes x=[-11.709501,-9.059499], r1.1 corner cylinders (faces #65/#66/#67/#80)
        translate([0, 0, 1.118182]) linear_extrude(3.442142) polygon(b1_post_profile);
        difference() {
            // b1_nook0: slot front-corner nook: bounded by wall x=-13.391926, front plane y=1.730215, r2 vertical fillet face #68
            translate([-13.391926, -0.269785, 1.118182]) cube([2, 2, 3.442142]);
            // b1_nook0_f: r2 vertical fillet: exact cylinder face #68
            translate([-11.391926, -0.269785, 0.618182]) cylinder(h=4.442142, r=2, $fn=b1_fn);
        }
        difference() {
            // b1_nook1: slot front-corner nook: bounded by wall x=-7.391926, front plane y=1.730215, r2 vertical fillet face #7
            translate([-9.391926, -0.269785, 1.118182]) cube([2, 2, 3.442142]);
