// hinge system: clevis gap + knuckle relief + pin bore + snap-pin pockets (all exact B-rep faces; see sources)
module b0_hinge_cuts() {
    union() {
        // b0_gap: clevis gap between exact inner-wall planes #79/#8; front wall = exact tilted plane #45
        rotate([90, 0, 90]) translate([0, 0, -28.076732]) linear_extrude(6) polygon(b0_gap_profile);
        // b0_relief: knuckle relief: exact cylinder face #80
        translate([-28.076732, -15.364044, 8.17051]) rotate(a=90, v=[0, 1, 0]) cylinder(h=6, r=7.5, $fn=b0_fn);
        // b0_pin_bore: hinge pin bore: exact cylinder faces #41/#43/#46/#47 between the exact annulus planes
        translate([-29.076732, -15.364044, 8.17051]) rotate(a=90, v=[0, 1, 0]) cylinder(h=8, r=2.25, $fn=b0_fn);
        // b0_pocketL: snap-pin pocket: exact full-circle cylinder face #25
        translate([-32.102524, -15.364044, 8.17051]) rotate(a=90, v=[0, 1, 0]) cylinder(h=3.025792, r=2.75, $fn=b0_fn);
        // b0_pocketR: right pocket: same radius as face-measured left pocket; breaks out through the skin (annulus plane at the bore band end)
        translate([-21.076732, -15.364044, 8.17051]) rotate(a=90, v=[0, 1, 0]) cylinder(h=5.698537, r=2.75, $fn=b0_fn);
    }
}

