module b0_tendon_cuts() {
    union() {
        // b0_slot: tendon slot: exact wall planes #79/#8, ceiling plane z=4.818769, r2 ceiling coves (faces #81/#89), front wall plane #6; rear overshoots into the gap
        rotate([0, -90, -90]) translate([0, 0, -12.612429]) linear_extrude(14.85) polygon(b0_slot_profile);
